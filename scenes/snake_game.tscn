[sub_resource type="Shader" id="Shader_score_fire"]
code = "shader_type canvas_item;

uniform float flame_speed : hint_range(0.2, 8.0) = 2.9;
uniform float warp : hint_range(0.0, 0.05) = 0.013;
uniform float glow : hint_range(0.0, 2.0) = 0.8;

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	uv.y += sin((UV.x * 16.0) - (t * flame_speed * 1.3)) * warp;
	uv.x += cos((UV.y * 23.0) + (t * flame_speed)) * warp * 0.55;

	float core = texture(TEXTURE, uv).a;
	vec2 px = TEXTURE_PIXEL_SIZE * 1.8;
	float halo = 0.0;
	halo += texture(TEXTURE, uv + vec2(px.x, 0.0)).a;
	halo += texture(TEXTURE, uv - vec2(px.x, 0.0)).a;
	halo += texture(TEXTURE, uv + vec2(0.0, px.y)).a;
	halo += texture(TEXTURE, uv - vec2(0.0, px.y)).a;
	halo += texture(TEXTURE, uv + px).a;
	halo += texture(TEXTURE, uv - px).a;
	halo /= 6.0;

	float flame = clamp((1.0 - UV.y) + sin((UV.x * 30.0) + (t * flame_speed * 1.7)) * 0.18, 0.0, 1.0);
	vec3 deep = vec3(0.75, 0.10, 0.02);
	vec3 mid = vec3(1.00, 0.42, 0.04);
	vec3 hot = vec3(1.00, 0.92, 0.34);
	vec3 fire = mix(deep, mid, flame);
	fire = mix(fire, hot, smoothstep(0.55, 1.0, flame));

	float pulse = 0.92 + sin(t * 6.5 + UV.x * 13.0) * 0.08;
	float alpha = clamp(core * 0.95 + halo * 0.7 * glow, 0.0, 1.0) * pulse;
	vec3 color = mix(fire, hot, clamp(halo * glow, 0.0, 1.0));
	COLOR = vec4(color, COLOR.a * alpha);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_score_fire"]
shader = SubResource("Shader_score_fire")
shader_parameter/flame_speed = 2.9
shader_parameter/warp = 0.013
shader_parameter/glow = 0.8

[sub_resource type="Shader" id="Shader_length_glitch"]
code = "shader_type canvas_item;

uniform float warp_amount : hint_range(0.0, 0.06) = 0.024;
uniform float wave_speed : hint_range(0.1, 8.0) = 2.3;
uniform float blur_radius : hint_range(0.0, 6.0) = 2.0;
uniform float glow_strength : hint_range(0.0, 2.0) = 0.7;
uniform float rainbow_speed : hint_range(0.1, 4.0) = 1.1;

vec3 hsv2rgb(vec3 c) {
	vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
	vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
	return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
}

void fragment() {
	vec2 uv = UV;
	float t = TIME;

	float waveA = sin((UV.y * 24.0) + (t * wave_speed));
	float waveB = cos((UV.x * 17.0) - (t * wave_speed * 0.82));
	uv.x += waveA * warp_amount;
	uv.y += waveB * warp_amount * 0.6;

	vec2 px = TEXTURE_PIXEL_SIZE * blur_radius;
	float core = texture(TEXTURE, uv).a;
	float glow = 0.0;
	glow += texture(TEXTURE, uv + vec2(px.x, 0.0)).a;
	glow += texture(TEXTURE, uv - vec2(px.x, 0.0)).a;
	glow += texture(TEXTURE, uv + vec2(0.0, px.y)).a;
	glow += texture(TEXTURE, uv - vec2(0.0, px.y)).a;
	glow += texture(TEXTURE, uv + px).a;
	glow += texture(TEXTURE, uv - px).a;
	glow += texture(TEXTURE, uv + vec2(px.x, -px.y)).a;
	glow += texture(TEXTURE, uv + vec2(-px.x, px.y)).a;
	glow /= 8.0;

	float alpha = clamp(core * 0.85 + glow * 0.75, 0.0, 1.0);
	float pulse = 0.9 + sin(t * 3.0 + UV.y * 12.0) * 0.1;
	alpha *= pulse;

	float hue = fract((UV.x * 0.35) + (UV.y * 0.18) + t * rainbow_speed);
	vec3 magic = hsv2rgb(vec3(hue, 0.75, 1.0));
	vec3 coreColor = mix(vec3(0.85, 0.95, 1.0), magic, 0.75);
	vec3 auraColor = hsv2rgb(vec3(fract(hue + 0.18), 0.55, 1.0));

	vec3 color = mix(coreColor, auraColor, clamp(glow * glow_strength, 0.0, 1.0));
	float sparkle = smoothstep(0.85, 1.0, sin((UV.x + UV.y) * 44.0 + t * 6.0));
	color += sparkle * 0.08;

	COLOR = vec4(color, COLOR.a * alpha);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_length_glitch"]
shader = SubResource("Shader_length_glitch")
shader_parameter/warp_amount = 0.024
shader_parameter/wave_speed = 2.3
shader_parameter/blur_radius = 2.0
shader_parameter/glow_strength = 0.7
shader_parameter/rainbow_speed = 1.1

